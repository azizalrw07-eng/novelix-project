<!DOCTYPE html>
<html>
<head>
    <title>Buy</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

<div class="container mt-5">

    <h1 class="page-title text-center">Buy Page</h1>

    <div class="row justify-content-center align-items-center">

        <div class="col-md-6">

            <div class="card p-4 shadow-lg rounded-4">

                <form id="buyForm" action="/buy" method="POST">

                    <h3 class="mb-4">
                        Total:
                        <span class="text-success">
                            <span id="totalText"></span> SR
                        </span>
                    </h3>

                    <input type="hidden" name="total" id="totalInput">

                    <h5>Payment Method</h5>

                    <div class="mb-3">
                        <input type="radio" name="payment" value="Visa" checked>
                        Visa

                        <input class="ms-3" type="radio" name="payment" value="Cash">
                        Cash
                    </div>

                    <textarea class="form-control mb-3"
                              name="note"
                              rows="5"
                              placeholder="Write your note"></textarea>

                    <button type="button"
                            class="btn btn-success btn-lg w-100"
                            onclick="confirmBuy()">
                        Submit Order
                    </button>

                </form>

            </div>

        </div>

        <div class="col-md-5 text-center mt-4 mt-md-0">

            <video width="100%" Length="400"
                   class="rounded-4 shadow-lg"
                   controls
                   autoplay
                   muted
                   loop>

                <source src="https://cdn.pixabay.com/video/2021/08/04/83894-584995980_large.mp4"
                        type="video/mp4">

            </video>

        </div>

    </div>

</div>


<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>

    let total = localStorage.getItem("totalPrice") || 0;

    document.getElementById("totalText").innerHTML = total;
    document.getElementById("totalInput").value = total;


    function confirmBuy(){

        let payment =
            document.querySelector('input[name="payment"]:checked').value;

        Swal.fire({
            title: "Confirm Purchase",
            text: "Total Pay: " + total + " SR | Payment: " + payment,
            icon: "question",
            showCancelButton: true,
            confirmButtonText: "Yes, Buy",
            cancelButtonText: "Cancel"
        }).then((result)=>{

            if(result.isConfirmed){
                document.getElementById("buyForm").submit();
            }

        });

    }

</script>

</body>
</html>