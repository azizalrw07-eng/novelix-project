<!DOCTYPE html>
<html>
<head>
    <title>My Cart</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

<div class="container mt-5">

    <h1 class="page-title text-center">My Shopping Cart</h1>

    <div class="card p-4 shadow-lg rounded-4">

        <table class="table table-hover text-center align-middle">

            <thead class="table-dark">
                <tr>
                    <th>Book Name</th>
                    <th>Price</th>
                    <th>Quantity</th>
                    <th>Total</th>
                    <th>Action</th>
                </tr>
            </thead>

            <tbody id="cartBody"></tbody>

        </table>

        <div class="text-end mt-4">
            <h2>
                Total:
                <span class="text-success">
                    <span id="total"></span> SR
                </span>
            </h2>
        </div>

        <div class="text-center mt-4">
            <button class="btn btn-success btn-lg" onclick="checkout()">
                Checkout
            </button>
        </div>

    </div>

</div>


<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>

let cart = JSON.parse(localStorage.getItem("cart")) || [];
let cartBody = document.getElementById("cartBody");
let total = 0;

function displayCart(){

    cartBody.innerHTML = "";
    total = 0;

    cart.forEach(function(item, index){

        let itemTotal = item.price * item.quantity;
        total += itemTotal;

        cartBody.innerHTML += `
            <tr>
                <td>${item.name}</td>
                <td>${item.price}</td>
                <td>${item.quantity}</td>
                <td>${itemTotal}</td>
                <td>
                    <button class="btn btn-danger btn-sm" onclick="removeItem(${index})">
                        Remove
                    </button>
                </td>
            </tr>
        `;

    });

    document.getElementById("total").innerHTML = total;
}
function removeItem(index){

    if(cart[index].quantity > 1){

        cart[index].quantity -= 1;
    }

    else{

        cart.splice(index, 1);
    }

    localStorage.setItem("cart", JSON.stringify(cart));

    localStorage.setItem("itemsNumber", cart.length);

    displayCart();
}

function checkout(){

    localStorage.setItem("totalPrice", total);
    localStorage.setItem("itemsNumber", cart.length);

    Swal.fire({
        title: "Success!",
        text: "Your order has been added successfully",
        icon: "success",
        confirmButtonText: "Continue"
    }).then(()=>{
        window.location.href = "/buy";
    });

}

displayCart();

</script>

<div class="d-flex justify-content-between mt-4">

    <a href="/products"
       class="btn btn-secondary btn-lg">

        ← Previous

    </a>

    <a href="/buy"
       class="btn btn-dark btn-lg">

        Next →

    </a>

</div>
</body>
</html>