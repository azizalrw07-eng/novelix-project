<!DOCTYPE html>
<html>
<head>
    <title>My Cart</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

<div class="container mt-5">

    <h1 class="page-title text-center">My Shopping Cart</h1>

    <div class="row justify-content-center">

        <div class="col-md-8">

            <div class="card p-4 shadow-lg rounded-4">

                <table class="table table-hover text-center align-middle">

                    <thead class="table-dark">
                        <tr>
                            <th>Book Name</th>
                            <th>Price</th>
                            <th>Quantity</th>
                        </tr>
                    </thead>

                    <tbody>

                        <tr>
                            <td id="bookName"></td>
                            <td id="bookPrice"></td>
                            <td>1</td>
                        </tr>

                    </tbody>

                </table>

                <div class="text-end mt-4">

                    <h2>
                        Total:
                        <span class="text-success">
                            <span id="total"></span> SR
                        </span>
                    </h2>

                </div>

                <div class="text-center mt-4">

                    <button class="btn btn-success btn-lg"
                            onclick="checkout()">

                        Checkout

                    </button>

                </div>

            </div>

        </div>

    </div>

</div>


<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>

    let name = localStorage.getItem("bookName");
    let price = localStorage.getItem("bookPrice");

    document.getElementById("bookName").innerHTML =
        name || "No Book";

    document.getElementById("bookPrice").innerHTML =
        price || "0";

    document.getElementById("total").innerHTML =
        price || "0";


    function checkout(){

        localStorage.setItem("totalPrice", price);
        localStorage.setItem("itemsNumber", 1);

        Swal.fire({
            title: "Success!",
            text: "Your order has been added successfully",
            icon: "success",
            confirmButtonText: "Continue"
        })

        .then(()=>{

            window.location.href = "/buy";

        });

    }

</script>

</body>
</html>