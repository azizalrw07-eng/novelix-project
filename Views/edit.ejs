<!DOCTYPE html>
<html>
<head>
    <title>Edit Book</title>
</head>
<body>

<h1>Edit Book</h1>

<form action="/update-item/<%= item.id %>" method="POST">

    <input type="text" name="title" value="<%= item.title %>" required><br><br>

    <input type="text" name="description" value="<%= item.description %>" required><br><br>

    <input type="number" name="price" value="<%= item.price %>" required><br><br>

    <input type="text" name="image" value="<%= item.image %>" required><br><br>

    <button type="submit">Update Book</button>

</form>

<br>
<a href="/manage">Back</a>

</body>
</html>