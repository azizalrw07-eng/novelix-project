<!DOCTYPE html>
<html>
<head>
    <title>Novelix Home</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
        <a class="navbar-brand" href="/home">📚 Novelix</a>

        <div class="navbar-nav">
            <a class="nav-link" href="/home">Home</a>
            <a class="nav-link" href="/products">Our Products</a>
            <a class="nav-link" href="/search">Search Product</a>
       <a class="nav-link" href="/cart">

    MyCart

    <span class="badge bg-danger" id="cartBadge">
        0
    </span>

</a>
            <a class="nav-link" href="/buy">Buy</a>
            <a class="nav-link" href="/manage">Manage Items</a>
            <a class="nav-link" href="/logout">Logout</a>
        </div>
    </div>
</nav>
<div class="container text-center mt-4">
    <h1>Welcome <%= username %></h1>
</div>

<div id="bookSlider" class="carousel slide" data-bs-ride="carousel">
    <div class="carousel-inner">

        <div class="carousel-item active">
            <img src="/images/atomic.jpg" class="d-block w-100" style="height:400px; object-fit:contain; background:#eee;">
        </div>

        <div class="carousel-item">
            <img src="/images/richdad.jpg" class="d-block w-100" style="height:400px; object-fit:contain; background:#eee;">
        </div>

        <div class="carousel-item">
            <img src="/images/alchemist.jpg" class="d-block w-100" style="height:400px; object-fit:contain; background:#eee;">
        </div>

        <div class="carousel-item">
            <img src="/images/deepwork.jpg" class="d-block w-100" style="height:400px; object-fit:contain; background:#eee;">
        </div>

    </div>

    <button class="carousel-control-prev" type="button" data-bs-target="#bookSlider" data-bs-slide="prev">
        <span class="carousel-control-prev-icon"></span>
    </button>

    <button class="carousel-control-next" type="button" data-bs-target="#bookSlider" data-bs-slide="next">
        <span class="carousel-control-next-icon"></span>
    </button>
</div>

<div class="container mt-5 text-center">
    <div class="p-5 bg-light rounded">
        <h1>Welcome to Novelix Book Store</h1>
        <p class="lead">
            Novelix is an online bookstore that offers novels, self-development,
            finance, and programming books.
        </p>
    </div>
</div>
<div class="container mt-5">
    <h2 class="text-center mb-4">Our Products</h2>

    <div class="row text-center">
        <div class="col-md-3 mb-4"><img src="/images/atomic.jpg" class="img-fluid product-img"><h5>Atomic Habits</h5></div>
        <div class="col-md-3 mb-4"><img src="/images/richdad.jpg" class="img-fluid product-img"><h5>Rich Dad Poor Dad</h5></div>
        <div class="col-md-3 mb-4"><img src="/images/alchemist.jpg" class="img-fluid product-img"><h5>The Alchemist</h5></div>
        <div class="col-md-3 mb-4"><img src="/images/deepwork.jpg" class="img-fluid product-img"><h5>Deep Work</h5></div>

        <div class="col-md-3 mb-4"><img src="/images/cleancode.jpg" class="img-fluid product-img"><h5>Clean Code</h5></div>
        <div class="col-md-3 mb-4"><img src="/images/harrypotter.jpg" class="img-fluid product-img"><h5>Harry Potter</h5></div>
        <div class="col-md-3 mb-4"><img src="/images/thinkgrow.jpg" class="img-fluid product-img"><h5>Think and Grow Rich</h5></div>
        <div class="col-md-3 mb-4"><img src="/images/money.jpg" class="img-fluid product-img"><h5>Psychology of Money</h5></div>
    </div>
</div>

<div class="container mt-5">
    <h2 class="text-center mb-4">Our Services</h2>

    <div class="row">
        <div class="col-md-4">
            <div class="card p-3 text-center">
                <h4>Fast Delivery</h4>
                <p>We deliver books quickly to customers.</p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card p-3 text-center">
                <h4>Best Prices</h4>
                <p>We provide books with affordable prices.</p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card p-3 text-center">
                <h4>Many Categories</h4>
                <p>We offer different types of books.</p>
            </div>
        </div>
    </div>
</div>
