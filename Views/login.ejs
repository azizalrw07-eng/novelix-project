<!DOCTYPE html>
<html>
<head>

    <title>Novelix Login</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
 body{
            min-height:100vh;
            display:flex;
            align-items:center;
            justify-content:center;
        }

        .login-box{
            background:rgba(255,255,255,0.90);
            padding:35px;
            border-radius:25px;
            box-shadow:0 10px 30px rgba(0,0,0,0.2);
        }

        .login-title{
            font-weight:bold;
            color:#2b2118;
        }

        .form-control{
            border-radius:12px;
            padding:12px;
        }

        .btn-login{
            background:#243b55;
            color:white;
            border-radius:12px;
            padding:12px;
            width:100%;
            font-size:18px;
            transition:0.3s;
        }

        .btn-login:hover{
            background:#141e30;
            transform:scale(1.03);
        }

        .book-icon{
            font-size:55px;
            text-align:center;
            margin-bottom:10px;
        }

    </style>

</head>

<body>

<div class="login-box">

    <div class="book-icon">
        📚
    </div>

    <h1 class="login-title">
        Welcome To Novelix
    </h1>

    <form action="/login" method="POST">

        <div class="mb-3">

            <label class="form-label">
                Username
            </label>

            <input type="text"
                   name="username"
                   class="form-control"
                   placeholder="Enter Username"
                   required>

        </div>

        <div class="mb-4">

            <label class="form-label">
                Password
            </label>

            <input type="password"
                   name="password"
                   class="form-control"
                   placeholder="Enter Password"
                   required>

        </div>

        <button type="submit" class="btn btn-login">

            Login

        </button>

        <div class="text-center mt-4">

            <a href="/register">
                Create New Account
            </a>

        </div>

    </form>

</div>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<% if(typeof error !== 'undefined'){ %>

<script>

Swal.fire({
    icon: "error",
    title: "Login Failed",
    text: "<%= error %>",
    confirmButtonColor: "#243b55"
});

</script>

<% } %>

</body>
</html>