<!DOCTYPE html>
<html>
<head>
    <title>Manage Items</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body class="container mt-5">

<h1 class="text-center mb-4">Manage Books</h1>

<button class="btn btn-success mb-4" data-bs-toggle="modal" data-bs-target="#addModal">
    Add New Book
</button>

<table class="table table-bordered table-striped text-center">
    <tr class="table-dark">
        <th>Title</th>
        <th>Description</th>
        <th>Price</th>
        <th>Image</th>
        <th>Actions</th>
    </tr>

    <% items.forEach(function(item){ %>
    <tr>
        <td><%= item.title %></td>
        <td><%= item.description %></td>
        <td><%= item.price %> SR</td>
        <td><img src="/images/<%= item.image %>" width="70"></td>
        <td>
            <button class="btn btn-info btn-sm" data-bs-toggle="modal" data-bs-target="#detail<%= item.id %>">Detail</button>
            <button class="btn btn-warning btn-sm" data-bs-toggle="modal" data-bs-target="#edit<%= item.id %>">Update</button>
            <button class="btn btn-danger btn-sm" data-bs-toggle="modal" data-bs-target="#delete<%= item.id %>">Delete</button>
        </td>
    </tr>

    <!-- Detail Modal -->
    <div class="modal fade" id="detail<%= item.id %>">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5>Book Details</h5>
                    <button class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body text-center">
                    <img src="/images/<%= item.image %>" width="150">
                    <h3><%= item.title %></h3>
                    <p><%= item.description %></p>
                    <h4><%= item.price %> SR</h4>
                </div>
            </div>
        </div>
    </div>

    <!-- Edit Modal -->
    <div class="modal fade" id="edit<%= item.id %>">
        <div class="modal-dialog">
            <div class="modal-content">
                <form action="/update-item/<%= item.id %>" method="POST">
                    <div class="modal-header">
                        <h5>Update Book</h5>
                        <button class="btn-close" data-bs-dismiss="modal"></button>
                    </div>

                    <div class="modal-body">
                        <input class="form-control mb-2" type="text" name="title" value="<%= item.title %>" required>
                        <input class="form-control mb-2" type="text" name="description" value="<%= item.description %>" required>
                        <input class="form-control mb-2" type="number" name="price" value="<%= item.price %>" required>
                        <input class="form-control mb-2" type="text" name="image" value="<%= item.image %>" required>
                    </div>

                    <div class="modal-footer">
                        <button class="btn btn-warning" type="submit">Update</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Delete Modal -->
    <div class="modal fade" id="delete<%= item.id %>">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5>Delete Book</h5>
                    <button class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    Are you sure you want to delete <b><%= item.title %></b>?
                </div>

                <div class="modal-footer">
                    <a href="/delete-item/<%= item.id %>" class="btn btn-danger">Yes Delete</a>
                    <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                </div>
            </div>
        </div>
    </div>

    <% }) %>
</table>

<a href="/home" class="btn btn-dark">Back Home</a>

<!-- Add Modal -->
<div class="modal fade" id="addModal">
    <div class="modal-dialog">
        <div class="modal-content">

            <form action="/add-item" method="POST">
                <div class="modal-header">
                    <h5>Add New Book</h5>
                    <button class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <input class="form-control mb-2" type="text" name="title" placeholder="Book Title" required>
                    <input class="form-control mb-2" type="text" name="description" placeholder="Description" required>
                    <input class="form-control mb-2" type="number" name="price" placeholder="Price" required>
                    <input class="form-control mb-2" type="text" name="image" placeholder="Image name مثل book.jpg" required>
                </div>

                <div class="modal-footer">
                    <button class="btn btn-success" type="submit">Add Book</button>
                </div>
            </form>

        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>