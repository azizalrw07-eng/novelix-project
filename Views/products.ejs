<!DOCTYPE html>
<html>
<head>
    <title>Products</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

<div class="container mt-5">

    <h1 class="page-title text-center">Our Products</h1>

    <div class="row">

        <% products.forEach(function(item){ %>

            <div class="col-md-4 mb-4">

                <div class="book-card text-center p-4 h-100">

                    <h2><%= item.title %></h2>

                  <img src="/images/<%= item.image %>"
     class="img-fluid mb-3"
     style="
        width:100%;
        height:300px;
        object-fit:cover;
        border-radius:15px;
     ">

                    <p><%= item.description %></p>

                    <h3>Price: <%= item.price %> SR</h3>

                    <button class="btn btn-success"
                            onclick="addToCart('<%= item.title %>', '<%= item.price %>')">
                        Add To Cart
                    </button>

                </div>

            </div>

        <% }) %>

    </div>

</div>


<script>

function addToCart(name, price){

    localStorage.setItem("bookName", name);
    localStorage.setItem("bookPrice", price);
    localStorage.setItem("itemsNumber", 1);

    window.location.href = "/cart";
}

</script>

</body>
</html>