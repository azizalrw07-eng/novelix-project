<!DOCTYPE html>
<html>
<head>
    <title>Products</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

<div class="container mt-5">

    <h1 class="page-title text-center">Our Products</h1>

    <div class="row">

        <% products.forEach(function(item){ %>

            <div class="col-md-4 mb-4">

                <div class="book-card text-center p-4 h-100">

                    <h2><%= item.title %></h2>

                  <img src="/images/<%= item.image %>"
     class="img-fluid mb-3"
     style="
        width:100%;
        height:300px;
        object-fit:cover;
        border-radius:15px;
     ">

                    <p><%= item.description %></p>

                    <h3>Price: <%= item.price %> SR</h3>

                    <button class="btn btn-success"
                            onclick="addToCart('<%= item.title %>', '<%= item.price %>')">
                        Add To Cart
                    </button>

                </div>

            </div>

        <% }) %>

    </div>

</div>

<script>
function addToCart(name, price){

    let cart = JSON.parse(localStorage.getItem("cart")) || [];

    let item = cart.find(product => product.name === name);

    if(item){
        item.quantity += 1;
    } else {
        cart.push({
            name: name,
            price: Number(price),
            quantity: 1
        });
    }

    localStorage.setItem("cart", JSON.stringify(cart));
    localStorage.setItem("itemsNumber", cart.length);

   Swal.fire({
    title: "Added!",
    text: "Book added to cart successfully",
    icon: "success",
    timer: 1500,
    showConfirmButton: false
});
}
localStorage.setItem("itemsNumber", cart.length);

Swal.fire({
    title: "Added To Cart!",
    text: "The book has been added successfully",
    icon: "success",
    confirmButtonText: "OK"


});

</script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<div class="d-flex justify-content-between mt-5">

    <a href="/home"
       class="btn btn-secondary">

        ← Previous

    </a>

    <a href="/cart"
       class="btn btn-dark">

        Next →

    </a>

</div>
</body>
</html>