<!DOCTYPE html>
<html>
<head>
    <title>Search Product</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>
</head>

<body>

<div class="container mt-5">

    <h1 class="page-title text-center">Search Product</h1>

    <form action="/search" method="POST" class="row justify-content-center mb-5">

        <div class="col-md-6">
            <input type="text"
                   name="bookname"
                   class="form-control form-control-lg"
                   placeholder="Enter book name"
                   required>
        </div>

        <div class="col-md-2">
            <button type="submit" class="btn btn-success btn-lg w-100">
                Search
            </button>
        </div>

    </form>


    <% if(typeof product !== "undefined" && product.length > 0){ %>

        <div class="row">

            <% product.forEach(function(item){ %>

                <div class="col-md-4 mb-4 animate__animated animate__fadeInDownBig">

                    <div class="book-card text-center p-4 h-100">

                        <h2><%= item.title %></h2>

                        <img src="/images/<%= item.image %>"
                             class="img-fluid mb-3"
                             style="height:250px; object-fit:contain;">

                        <p><%= item.description %></p>

                        <h3>Price: <%= item.price %> SR</h3>

                        <button class="btn btn-success"
                                onclick="addToCart('<%= item.title %>', '<%= item.price %>')">
                            Add To Cart
                        </button>

                    </div>

                </div>

            <% }) %>

        </div>

    <% } else if(typeof product !== "undefined"){ %>

        <div class="alert alert-warning text-center">
            No product found
        </div>

    <% } %>

</div>

<script>
function addToCart(name, price){

    let cart = JSON.parse(localStorage.getItem("cart")) || [];

    let item = cart.find(product => product.name === name);

    if(item){
        item.quantity += 1;
    } else {
        cart.push({
            name: name,
            price: Number(price),
            quantity: 1
        });
    }

    localStorage.setItem("cart", JSON.stringify(cart));
    localStorage.setItem("itemsNumber", cart.length);

    window.location.href = "/cart";
}
</script>

</body>
</html>